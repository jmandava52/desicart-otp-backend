TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email OTP via Resend (optional — only needed if you want to send
# codes to an email address instead of / in addition to SMS)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres database (Neon free tier) — required for orders and dasher
# accounts to persist. Get this from your Neon project's dashboard.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

PORT=3000
